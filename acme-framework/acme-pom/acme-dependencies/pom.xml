<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
		 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
		 xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             http://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>

	<parent>
		<groupId>org.acme</groupId>
		<artifactId>acme-pom</artifactId>
		<version>1.0.0-SNAPSHOT</version>
		<relativePath>../pom.xml</relativePath>
	</parent>

	<artifactId>acme-dependencies</artifactId>
	<packaging>pom</packaging>

	<name>Acme Dependencies</name>
	<description>BOM (Bill of Materials) for dependency version management</description>

	<properties>
		<!-- Spring Boot -->
		<spring-boot.version>3.5.13</spring-boot.version>
		<lombok.version>1.18.44</lombok.version>
		<!-- Spring dependency version overrides -->
		<commons-lang3.version>3.18.0</commons-lang3.version>
		<jackson-bom.version>2.18.6</jackson-bom.version>
		<!-- SpringDoc OpenAPI -->
		<springdoc-openapi-webmvc.version>2.8.14</springdoc-openapi-webmvc.version>
		<springdoc-openapi-webflux.version>2.8.14</springdoc-openapi-webflux.version>
		<!-- Annotation Processing -->
		<lombok-mapstruct-binding.version>0.2.0</lombok-mapstruct-binding.version>
		<mapstruct.version>1.6.3</mapstruct.version>
		<!-- Code Quality -->
		<spotless.version>2.43.0</spotless.version>
	</properties>

	<dependencyManagement>
		<dependencies>
			<!-- Override Jackson (GHSA-72hv-8253-57qq) -->
			<dependency>
				<groupId>com.fasterxml.jackson</groupId>
				<artifactId>jackson-bom</artifactId>
				<version>${jackson-bom.version}</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>
			<!-- Override Commons Lang 3 (CVE-2025-48924) -->
			<dependency>
				<groupId>org.apache.commons</groupId>
				<artifactId>commons-lang3</artifactId>
				<version>${commons-lang3.version}</version>
			</dependency>

			<!-- Spring Boot BOM -->
			<dependency>
				<groupId>org.springframework.boot</groupId>
				<artifactId>spring-boot-dependencies</artifactId>
				<version>${spring-boot.version}</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>

			<!-- Lombok -->
			<dependency>
				<groupId>org.projectlombok</groupId>
				<artifactId>lombok</artifactId>
				<version>${lombok.version}</version>
			</dependency>
			<!-- Lombok Mapstruct Binding -->
			<dependency>
				<groupId>org.projectlombok</groupId>
				<artifactId>lombok-mapstruct-binding</artifactId>
				<version>${lombok-mapstruct-binding.version}</version>
			</dependency>
			<!-- Mapstruct -->
			<dependency>
				<groupId>org.mapstruct</groupId>
				<artifactId>mapstruct</artifactId>
				<version>${mapstruct.version}</version>
			</dependency>
			<dependency>
				<groupId>org.mapstruct</groupId>
				<artifactId>mapstruct-processor</artifactId>
				<version>${mapstruct.version}</version>
			</dependency>

			<!-- SpringDoc OpenAPI WebMVC -->
			<dependency>
				<groupId>org.springdoc</groupId>
				<artifactId>springdoc-openapi-starter-webmvc-ui</artifactId>
				<version>${springdoc-openapi-webmvc.version}</version>
			</dependency>
			<!-- SpringDoc OpenAPI WebFlux -->
			<dependency>
				<groupId>org.springdoc</groupId>
				<artifactId>springdoc-openapi-starter-webflux-ui</artifactId>
				<version>${springdoc-openapi-webflux.version}</version>
			</dependency>

			<!-- External 2nd party libraries -->
			<dependency>
				<groupId>org.acme.auth</groupId>
				<artifactId>acme-auth-utils</artifactId>
				<version>${project.version}</version>
			</dependency>

			<!-- 1st party Acme libraries -->
			<dependency>
				<groupId>org.acme.security</groupId>
				<artifactId>acme-security-core</artifactId>
				<version>${project.version}</version>
			</dependency>
			<dependency>
				<groupId>org.acme.security</groupId>
				<artifactId>acme-security-webmvc</artifactId>
				<version>${project.version}</version>
			</dependency>
			<dependency>
				<groupId>org.acme.security</groupId>
				<artifactId>acme-security-webflux</artifactId>
				<version>${project.version}</version>
			</dependency>
			<dependency>
				<groupId>org.acme.persistence</groupId>
				<artifactId>acme-persistence-jpa</artifactId>
				<version>${project.version}</version>
			</dependency>
			<dependency>
				<groupId>org.acme.persistence</groupId>
				<artifactId>acme-persistence-r2dbc</artifactId>
				<version>${project.version}</version>
			</dependency>
			<dependency>
				<groupId>org.acme.test</groupId>
				<artifactId>acme-test-integration-classic</artifactId>
				<version>${project.version}</version>
			</dependency>
			<dependency>
				<groupId>org.acme.test</groupId>
				<artifactId>acme-test-integration-reactive</artifactId>
				<version>${project.version}</version>
			</dependency>
		</dependencies>
	</dependencyManagement>
</project>

